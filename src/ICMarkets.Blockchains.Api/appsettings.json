{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Blockchains": "Data Source=./data/blockchains.db"
  },
  "BlockCypher": {
    "BaseUrl": "https://api.blockcypher.com/v1",
    "ApiToken": null
  },
  "SnapshotWorker": {
    "Enabled": true,
    "Interval": "00:05:00"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
